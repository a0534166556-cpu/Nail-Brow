# העתיקי לקובץ .env.local ומלאי ערכים (קבצי .env/.env.local לא נכנסים ל-git).

# SendGrid — מכתב תודה אחרי קביעת תור (כשממלאים אימייל בטופס)
SENDGRID_API_KEY=

# חובה: כתובת שולח מאומתת ב-SendGrid (Single Sender או דומיין)
# דוגמה: Nail & Brow <booking@yourdomain.com>
BOOKING_EMAIL_FROM=

# אופציונלי במקום BOOKING_EMAIL_FROM:
# SENDGRID_FROM_EMAIL=

# אופציונלי — שם שמופיע במייל
# BOOKING_STUDIO_NAME=Nail & Brow

# כתובת בסיס של האתר (ללא סלאש בסוף) — לקישור בדוא״ל לכרטיס הגירוד אחרי 3 תורים
# BOOKING_PUBLIC_SITE_URL=https://www.example.com
